# ─────────────────────────────────────────────────────────────────────────────
# nifty_trend_options — strategy-local environment variables
# Copy/rename to strategy_runtime.nifty_trend_options.paper_live.env
# and set real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime wiring ────────────────────────────────────────────────────────────
STRATEGY_RUNTIME_STRATEGY=nifty_trend_options
STRATEGY_RUNTIME_FEED_SOURCE=broker
STRATEGY_RUNTIME_PROVIDER=upstox
STRATEGY_RUNTIME_TRADING_PROVIDER=paper
STRATEGY_RUNTIME_SYMBOL=NSE_INDEX|Nifty 50
STRATEGY_RUNTIME_TIMEFRAME=5m
STRATEGY_RUNTIME_POLL_SECONDS=30
STRATEGY_RUNTIME_LOOKBACK_BARS=60

# ── Position sizing ───────────────────────────────────────────────────────────
STRATEGY_RUNTIME_QUANTITY=1
STRATEGY_RUNTIME_MAX_POSITION_QTY=1

# ── Strategy-specific params (read via ctx.get_param) ────────────────────────
# Option expiry date. Leave blank to auto-select nearest weekly expiry.
NIFTY_OPTION_EXPIRY=
# Target option premium for strike selection (Rs)
NIFTY_TARGET_PREMIUM=200
# Tolerance around target premium: accept strikes within ±this many Rs
NIFTY_PREMIUM_TOLERANCE=50
# Stop loss as fraction of entry premium (0.5 = 50% of entry price)
NIFTY_STOP_LOSS_PREMIUM_PCT=0.50
# Number of ATM strikes in each direction to scan
NIFTY_STRIKE_SCAN_COUNT=10

# ── Indicators (ema_20, sma_20, macd are required by this strategy) ───────────
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,macd

# ── Risk override (runtime-level stop, acts as hard safety net) ───────────────
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.60

# ── Optional Telegram alerts ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
