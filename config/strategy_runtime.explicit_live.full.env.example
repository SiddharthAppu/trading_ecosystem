# strategy_runtime.explicit_live.full.env.example
#
# Purpose:
#   Comprehensive live-feed runtime example.
#   Use this when STRATEGY_RUNTIME_FEED_SOURCE=broker and the strategy should receive
#   live market data from the configured broker adapter.
#
# Important:
#   - The explicit source-table contract introduced for replay/backtest is not currently
#     required for broker mode, because live data does not originate from a DB table.
#   - This file still documents the full runtime parameter surface so operators can keep
#     one consistent config vocabulary across modes.
#
# -----------------------------------------------------------------------------
# FEED + PROVIDER SELECTION
# -----------------------------------------------------------------------------

# Required.
# broker means the runtime asks a live broker adapter for data instead of the replay engine.
STRATEGY_RUNTIME_FEED_SOURCE=broker

# Required.
# Market-data provider namespace.
# Examples:
#   upstox
#   fyers
STRATEGY_RUNTIME_PROVIDER=upstox

# Optional but recommended.
# Execution provider namespace.
# Use paper for simulation or a live adapter name for actual execution.
STRATEGY_RUNTIME_TRADING_PROVIDER=paper

# Required.
# Underlying symbol in the provider's live symbol format.
# Example for Upstox:
#   NSE_INDEX|Nifty 50
STRATEGY_RUNTIME_SYMBOL=NSE_INDEX|Nifty 50

# Required.
# Output timeframe consumed by the strategy.
# Allowed values currently handled by runtime aggregation:
#   1m
#   5m
#   10m
STRATEGY_RUNTIME_TIMEFRAME=5m

# -----------------------------------------------------------------------------
# STRATEGY + INDICATORS
# -----------------------------------------------------------------------------

# Required.
# Strategy name resolved by services/strategy_runtime/strategies.
STRATEGY_RUNTIME_STRATEGY=nifty_trend_options

# Optional custom plugin strategy class path.
STRATEGY_RUNTIME_STRATEGY_CLASS=

# Comma-separated indicator set computed for the strategy snapshot.
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd

# Indicator input semantics.
# In broker mode this usually remains bars_1m unless your strategy is explicitly tick-native.
STRATEGY_RUNTIME_INDICATOR_INPUT_MODE=bars_1m

# Historical bars retained in the snapshot history passed to strategies.
STRATEGY_RUNTIME_LOOKBACK_BARS=120

# Polling interval in seconds for broker polling mode.
# Lower values can increase load on adapters or broker APIs.
STRATEGY_RUNTIME_POLL_SECONDS=20

# Start automatically on API server startup.
STRATEGY_RUNTIME_AUTOSTART=true

# -----------------------------------------------------------------------------
# POSITION SIZING + RISK
# -----------------------------------------------------------------------------

STRATEGY_RUNTIME_LOT_QUANTITY=1
STRATEGY_RUNTIME_LOT_SIZE=75
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000
STRATEGY_RUNTIME_CAPITAL_MODEL=non_compounding
STRATEGY_RUNTIME_MAX_POSITION_LOTS=1
STRATEGY_RUNTIME_MAX_NOTIONAL=250000
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015

# -----------------------------------------------------------------------------
# LOGGING + NOTIFICATIONS
# -----------------------------------------------------------------------------

STRATEGY_RUNTIME_LOG_LEVEL=INFO
STRATEGY_RUNTIME_LOG_FILE=logs/strategy_runtime/runtime.log
TELEGRAM_ENABLED=false

# -----------------------------------------------------------------------------
# REPLAY / EXPLICIT SOURCE KEYS
# -----------------------------------------------------------------------------
# These are not required in broker mode today.
# They are included here so one operator can see the full vocabulary in one place.
# Leave them blank unless you deliberately want the same file to be repurposed later.

# Exact DB table for replay/backtest source data.
STRATEGY_RUNTIME_SOURCE_TABLE=

# Declared DB data kind for replay/backtest source table: bars or ticks.
STRATEGY_RUNTIME_SOURCE_DATA_KIND=

# Historical option table for replay/backtest option resolution.
STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE=

# Trading days per DB chunk for replay/backtest chunking.
STRATEGY_RUNTIME_DB_CHUNKING_TRADING_DAYS=

# Hard ceiling for estimated rows per replay/backtest chunk.
STRATEGY_RUNTIME_MAX_ROWS_PER_CHUNK=

# Replay websocket URL if this file is later adapted for replay mode.
STRATEGY_RUNTIME_REPLAY_WS_URL=ws://localhost:8765

# Historical replay data-type label for UI/logging if this file is later adapted for replay mode.
STRATEGY_RUNTIME_REPLAY_DATA_TYPE=market_ticks

# Replay speed multiplier if this file is later adapted for replay mode.
STRATEGY_RUNTIME_REPLAY_SPEED=5
STRATEGY_RUNTIME_REPLAY_START_TIME=
STRATEGY_RUNTIME_REPLAY_END_TIME=

# -----------------------------------------------------------------------------
# NIFTY TREND OPTIONS STRATEGY PARAMETERS
# -----------------------------------------------------------------------------

NIFTY_UNDERLYING_SYMBOL=NSE_INDEX|Nifty 50
NIFTY_OPTION_EXPIRY=
NIFTY_STRIKE_SCAN_COUNT=10
NIFTY_TARGET_PREMIUM=200.0
NIFTY_PREMIUM_TOLERANCE=50.0
NIFTY_STOP_LOSS_PREMIUM_PCT=0.50
NIFTY_ENTRY_START_TIME_IST=09:30
NIFTY_ENTRY_END_TIME_IST=15:00
NIFTY_FORCE_EXIT_1500_ENABLED=false
NIFTY_FORCE_EXIT_TIME_IST=15:00
NIFTY_FORCE_EXIT_DEBUG_ENABLED=false
NIFTY_FORCE_EXIT_DEBUG_TO_JOURNAL=false
NIFTY_EMA_PERIOD=20
NIFTY_SMA_PERIOD=20
NIFTY_MACD_FAST=12
NIFTY_MACD_SLOW=26
NIFTY_MACD_SIGNAL=9

# -----------------------------------------------------------------------------
# OPTIONAL GLOBAL / SELF-CONTAINED SETTINGS
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/trading_db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ASTRA_RECORDER_ENABLE_DB=true
ASTRA_RECORDER_ENABLE_FILE=true
