# strategy_runtime.backtest_example.env
#
# Template for backtest runs using scripts/strategy_backtest.py or START_BACKTEST_KIT.ps1.
# Copy and customize this file for each strategy backtest configuration.
#
# APPLIES TO: BT (Backtest Kit) adapter only.
# Keys marked [CLI-ONLY] are NOT read from this env file by the backtest adapter;
# they must be supplied as CLI arguments to strategy_backtest.py.
# Keys marked [IGNORED-BT] are not consumed in offline adapter execution but may appear
# in unified operator config files for reference/live parity.
#
# HOW KEYS ARE LOADED:
#   scripts/strategy_backtest.py reads env files via config.py and maps them to:
#   --lot-quantity, --lot-size, --initial-capital, --capital-model, etc.
#   CLI args always override env values.
#
# WHEN lot_quantity == -1 (auto-lot mode):
#   The backtest adapter automatically computes the number of lots to buy each bar as:
#     lots = floor(capital_available / (bar.close * lot_size))
#   This applies to BOTH non_compounding and compounding capital models.
#   If computed lots < 1 and no open position exists, the bar is skipped with an
#   INSUFFICIENT_FUNDS_SKIP journal event logged. The run continues to the next bar.

# ── Strategy identity ─────────────────────────────────────────────────────────
STRATEGY_RUNTIME_STRATEGY=ema_cross
# Optional plugin class (leave blank to use built-in strategy name lookup)
STRATEGY_RUNTIME_STRATEGY_CLASS=

# ── Symbol ────────────────────────────────────────────────────────────────────
# [IGNORED-BT] Backtest adapter uses CLI --index-symbol; this key is for live/replay.
STRATEGY_RUNTIME_SYMBOL=NSE:NIFTY50-INDEX

# ── Timeframe ─────────────────────────────────────────────────────────────────
STRATEGY_RUNTIME_TIMEFRAME=5m

# ── Indicators ────────────────────────────────────────────────────────────────
# List of indicators to compute. Format: comma-separated indicator names.
# Supported: ema_*, sma_*, rsi_*, macd, bollinger, etc.
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd

# ── Indicator tuning parameters ────────────────────────────────────────────────
# These are optimized by strategy_optimize.py. Copy values from optimizer output.
# Period for EMA (Exponential Moving Average)
NIFTY_EMA_PERIOD=20
# Period for SMA (Simple Moving Average)
NIFTY_SMA_PERIOD=20
# MACD parameters (fast period, slow period, signal period)
NIFTY_MACD_FAST=9
NIFTY_MACD_SLOW=21
NIFTY_MACD_SIGNAL=7
# RSI period
NIFTY_RSI_PERIOD=14

# ── Strategy signal parameters (NIFTY Trend Options example) ─────────────────
# These control entry/exit logic and are also optimized by the optimizer.
# Target premium level for entry signals (in rupees)
NIFTY_TARGET_PREMIUM=200.0
# Tolerance band around target premium (in rupees)
NIFTY_PREMIUM_TOLERANCE=60.0
# Stop-loss threshold as percentage of entry premium
NIFTY_STOP_LOSS_PREMIUM_PCT=0.35

# ── Lot sizing ────────────────────────────────────────────────────────────────
# Number of lots to trade per entry signal.
# Set to -1 to enable auto-lot mode (size dynamically from available capital).
STRATEGY_RUNTIME_LOT_QUANTITY=1
# Units per lot (instrument-specific, e.g. 75 for NIFTY options).
STRATEGY_RUNTIME_LOT_SIZE=75

# ── Capital model ─────────────────────────────────────────────────────────────
# non_compounding : lot quantity stays fixed; capital is refilled after each losing trade.
# compounding     : lot quantity scales with available capital; refill only when capital <= 0.
STRATEGY_RUNTIME_CAPITAL_MODEL=non_compounding
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000

# ── Position limits ───────────────────────────────────────────────────────────
# [IGNORED-BT] Max open lots enforced only in live/replay RuntimeRiskManager.
# Listed here for unified config reference only.
STRATEGY_RUNTIME_MAX_POSITION_LOTS=1

# ── Risk controls ─────────────────────────────────────────────────────────────
# [IGNORED-BT] Stop-loss and trailing-stop are enforced by live/replay risk manager.
# Listed here for unified config reference / future backtest risk parity.
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015

# ── Notifications ─────────────────────────────────────────────────────────────
# Always false for backtest runs — no Telegram alerts are sent.
TELEGRAM_ENABLED=false

# ── Provider (ignored by backtest adapter, for reference) ─────────────────────
# [IGNORED-BT] Live/replay keys. Included so this file can be used as a base for
# multi-mode unified configs.
STRATEGY_RUNTIME_PROVIDER=fyers
STRATEGY_RUNTIME_TRADING_PROVIDER=paper
STRATEGY_RUNTIME_FEED_SOURCE=replay_ws
