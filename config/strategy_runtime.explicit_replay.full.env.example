# strategy_runtime.explicit_replay.full.env.example
#
# Purpose:
#   Comprehensive replay/runtime configuration example with explicit source selection.
#   Use this when STRATEGY_RUNTIME_FEED_SOURCE=replay_ws and you want the runtime to
#   fail fast unless every required source parameter is provided.
#
# Usage:
#   1. Copy to a concrete file, for example:
#        config/strategy_runtime.nifty_trend_options.explicit_replay.env
#   2. Adjust values for your provider, symbol, timeframe, and source tables.
#   3. Start the runtime with that env file through your wrapper or manual export.
#
# Notes:
#   - This file is intentionally verbose. Nearly every setting includes a description,
#     allowed values, and whether it is required or optional.
#   - DATABASE_URL, TELEGRAM_BOT_TOKEN, and TELEGRAM_CHAT_ID usually live in config/.env,
#     but example placeholders are included at the bottom for completeness.
#   - With the current explicit-source contract, replay runs require:
#       STRATEGY_RUNTIME_SOURCE_TABLE
#       STRATEGY_RUNTIME_SOURCE_DATA_KIND
#       STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE
#       STRATEGY_RUNTIME_DB_CHUNKING_TRADING_DAYS
#       STRATEGY_RUNTIME_MAX_ROWS_PER_CHUNK
#
# -----------------------------------------------------------------------------
# FEED + PROVIDER SELECTION
# -----------------------------------------------------------------------------

# Required.
# Selects the incoming market-data source used by strategy_runtime.
# Allowed values:
#   broker    -> live broker adapter feed
#   replay_ws -> replay engine websocket feed
# For this file, keep it replay_ws.
STRATEGY_RUNTIME_FEED_SOURCE=replay_ws

# Required.
# Market-data provider namespace. Used for symbol interpretation, adapter selection,
# and run metadata. Typical values are:
#   fyers
#   upstox
# This should match the symbol format and source table you provide below.
STRATEGY_RUNTIME_PROVIDER=upstox

# Optional but recommended.
# Execution provider. Separate from the data provider.
# Typical values:
#   paper     -> simulated order execution
#   upstox    -> live or adapter-backed execution if supported
#   zerodha   -> live execution if the adapter exists and is configured
# For replay/paper testing, keep this as paper.
STRATEGY_RUNTIME_TRADING_PROVIDER=paper

# Required.
# The underlying symbol the strategy watches.
# Examples:
#   NSE:NIFTY50-INDEX      (Fyers style)
#   NSE_INDEX|Nifty 50     (Upstox style)
# The symbol must exist in the configured STRATEGY_RUNTIME_SOURCE_TABLE.
STRATEGY_RUNTIME_SYMBOL=NSE_INDEX|Nifty 50

# Required.
# Target output timeframe consumed by the strategy.
# Allowed values in the current runtime/backtest path:
#   1m
#   5m
#   10m
# If the source table is ticks, runtime/backtest aggregates ticks -> 1m -> this timeframe.
# If the source table is bars, runtime/backtest aggregates 1m bars -> this timeframe.
STRATEGY_RUNTIME_TIMEFRAME=5m

# -----------------------------------------------------------------------------
# EXPLICIT SOURCE CONTRACT
# -----------------------------------------------------------------------------

# Required for replay_ws.
# The exact database table holding the primary index/underlying data stream.
# Examples:
#   broker_fyers.market_ticks
#   broker_upstox.market_ticks
#   broker_fyers.ohlcv_1m
#   broker_upstox.ohlcv_1m
#   master_broker.ohlcv_1m
# This value must be schema.table and must match the declared data kind below.
STRATEGY_RUNTIME_SOURCE_TABLE=broker_upstox.market_ticks

# Required for replay_ws.
# Declares the kind of rows stored in STRATEGY_RUNTIME_SOURCE_TABLE.
# Allowed values:
#   ticks -> expects time, symbol, price, volume
#   bars  -> expects time, symbol, open, high, low, close, volume
# If this declaration does not match the real table schema, runtime/backtest should stop.
STRATEGY_RUNTIME_SOURCE_DATA_KIND=ticks

# Required for replay_ws and backtest parity.
# Historical options table used by the option resolver for chain discovery and quote lookup.
# Typical values:
#   master_broker.options_ohlc_1m_fromupstox
#   broker_upstox.options_ohlc
# This table must expose at least the columns required by ReplayOptionDataResolver
# such as time, symbol, open, high, low, close, expiry_date, strike_price,
# option_type, and nifty_spot.
STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE=master_broker.options_ohlc_1m_fromupstox

# Required for replay_ws and backtest parity.
# Number of trading days to fetch and process in one DB chunk.
# Example meanings:
#   1   -> one trading day at a time
#   5   -> one trading week at a time (roughly)
#   30  -> roughly one trading month per chunk
# Large values reduce DB round trips but increase in-memory footprint.
STRATEGY_RUNTIME_DB_CHUNKING_TRADING_DAYS=5

# Required for replay_ws and backtest parity.
# Hard fail ceiling for the estimated number of rows loaded in a single chunk.
# If the estimated row count exceeds this value, execution aborts before loading.
# This is especially important for tick tables.
# Example starting points:
#   100000    conservative for ticks
#   500000    larger machine / shorter symbols
#   5000      more than enough for 1m bars over a few days
STRATEGY_RUNTIME_MAX_ROWS_PER_CHUNK=100000

# -----------------------------------------------------------------------------
# REPLAY ENGINE CONNECTION
# -----------------------------------------------------------------------------

# Required for replay_ws.
# Replay engine websocket endpoint.
# Usually the local replay engine is exposed on ws://localhost:8765.
STRATEGY_RUNTIME_REPLAY_WS_URL=ws://localhost:8765

# Optional but commonly used.
# Replay engine source data type metadata. This is still useful for logs and UI,
# but the explicit source contract above is now the authoritative source selection.
# Typical values used historically:
#   market_ticks
#   ohlcv_1m
#   ohlcv_1min_from_ticks
#   options_ohlc
# Keep this aligned with STRATEGY_RUNTIME_SOURCE_DATA_KIND for operator clarity.
STRATEGY_RUNTIME_REPLAY_DATA_TYPE=market_ticks

# Optional.
# Replay speed multiplier. Higher means faster playback.
# Examples:
#   1   -> approximately real-time pacing
#   5   -> five times faster
#   20  -> fast scan testing
STRATEGY_RUNTIME_REPLAY_SPEED=5

# Optional but strongly recommended.
# Replay start time in ISO8601 format.
# Example:
#   2026-04-30T09:15:00+05:30
# Keep this aligned with market session boundaries where possible.
STRATEGY_RUNTIME_REPLAY_START_TIME=2026-04-30T09:15:00+05:30

# Optional but strongly recommended.
# Replay end time in ISO8601 format.
# Example:
#   2026-04-30T15:30:00+05:30
STRATEGY_RUNTIME_REPLAY_END_TIME=2026-04-30T15:30:00+05:30

# -----------------------------------------------------------------------------
# STRATEGY SELECTION + EXECUTION CONTROLS
# -----------------------------------------------------------------------------

# Required.
# Built-in strategy module name, for example:
#   ema_cross
#   nifty_trend_options
STRATEGY_RUNTIME_STRATEGY=nifty_trend_options

# Optional.
# Fully qualified class path if you want to load a custom strategy class directly.
# Leave blank when using built-in strategy lookup by STRATEGY_RUNTIME_STRATEGY.
STRATEGY_RUNTIME_STRATEGY_CLASS=

# Optional.
# Comma-separated indicator list computed for the strategy.
# Example indicators in current codebase include:
#   ema_20,sma_20,rsi_14,macd
# Use values your strategy actually reads; unused indicators only add compute cost.
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd

# Optional.
# Describes how indicators should interpret the incoming feed.
# Allowed values:
#   bars_1m -> closed 1m bars are the atomic indicator input
#   ticks   -> raw ticks are used directly where supported
# For tick sources with stable parity, bars_1m is the recommended setting.
STRATEGY_RUNTIME_INDICATOR_INPUT_MODE=bars_1m

# Optional.
# Historical lookback window kept in memory for strategy evaluation snapshots.
# Larger values allow longer indicator warmup but increase memory use.
STRATEGY_RUNTIME_LOOKBACK_BARS=120

# Optional.
# Polling interval in seconds for broker polling mode.
# Ignored for replay_ws because replay is push-based.
STRATEGY_RUNTIME_POLL_SECONDS=20

# Optional.
# Automatically start the runtime loop when the API server boots.
# true  -> runtime starts on server startup
# false -> runtime waits for an explicit /runtime/start call
STRATEGY_RUNTIME_AUTOSTART=true

# -----------------------------------------------------------------------------
# POSITION SIZING + RISK
# -----------------------------------------------------------------------------

# Required for most strategies.
# Base lot count per entry.
# Special value:
#   -1 -> auto-lot mode, size dynamically from available capital
STRATEGY_RUNTIME_LOT_QUANTITY=1

# Required.
# Instrument lot size.
# Examples:
#   75  for many NIFTY option contracts historically
#   15  for some BANKNIFTY expiries historically
# Ensure this matches the instrument family being traded.
STRATEGY_RUNTIME_LOT_SIZE=75

# Required.
# Starting capital used for paper execution and capital-model logic.
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000

# Required.
# Capital sizing mode.
# Allowed values:
#   non_compounding -> base lot logic stays fixed; adapter may refill to baseline after losses
#   compounding     -> effective size scales with available capital
STRATEGY_RUNTIME_CAPITAL_MODEL=non_compounding

# Optional.
# Maximum lots allowed in an open position for a single symbol.
STRATEGY_RUNTIME_MAX_POSITION_LOTS=1

# Optional.
# Maximum notional allowed for a single entry.
# Formula is roughly quantity_units * price.
STRATEGY_RUNTIME_MAX_NOTIONAL=250000

# Optional.
# Runtime risk-layer stop loss as a fraction of entry price.
# Example:
#   0.01 -> 1%
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01

# Optional.
# Runtime trailing stop as a fraction of the trailing peak.
# Example:
#   0.015 -> 1.5%
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015

# -----------------------------------------------------------------------------
# LOGGING + NOTIFICATIONS
# -----------------------------------------------------------------------------

# Optional.
# Logging verbosity.
# Typical values:
#   DEBUG
#   INFO
#   WARNING
#   ERROR
STRATEGY_RUNTIME_LOG_LEVEL=INFO

# Optional.
# Log file written by runtime.
# Relative paths are resolved from the repo root by the launcher/runtime.
STRATEGY_RUNTIME_LOG_FILE=logs/strategy_runtime/runtime.log

# Optional.
# Enables Telegram notifications if TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are also set.
TELEGRAM_ENABLED=false

# -----------------------------------------------------------------------------
# NIFTY TREND OPTIONS STRATEGY PARAMETERS
# -----------------------------------------------------------------------------
# These are only used when STRATEGY_RUNTIME_STRATEGY=nifty_trend_options.
# They are harmless but ignored by strategies that do not read them.

# Underlying symbol used for option-chain lookup by the strategy.
# This often differs from STRATEGY_RUNTIME_SYMBOL only when your execution or
# data adapter needs a different neutral/underlying representation.
NIFTY_UNDERLYING_SYMBOL=NSE_INDEX|Nifty 50

# Optional fixed expiry override in ISO format YYYY-MM-DD.
# Leave blank to auto-select the nearest available expiry from the resolver.
NIFTY_OPTION_EXPIRY=

# Number of strikes to scan around ATM on each side when choosing an option.
NIFTY_STRIKE_SCAN_COUNT=10

# Target premium in rupees when searching for the option contract to trade.
NIFTY_TARGET_PREMIUM=200.0

# Allowed deviation from the target premium.
# Example:
#   target=200, tolerance=50 -> any option in [150, 250] can be eligible.
NIFTY_PREMIUM_TOLERANCE=50.0

# Risk per trade as a fraction of entry premium.
# Example:
#   0.50 -> stop is 50% below entry premium and target is derived from strategy logic.
NIFTY_STOP_LOSS_PREMIUM_PCT=0.50

# Earliest IST time at which new entries may be opened.
NIFTY_ENTRY_START_TIME_IST=09:30

# Last IST time before which new entries may be opened.
# The strategy treats the end bound as exclusive for new entries.
NIFTY_ENTRY_END_TIME_IST=15:00

# Whether to force-close open positions after the configured cutoff time.
NIFTY_FORCE_EXIT_1500_ENABLED=false

# Forced exit cutoff time in IST.
NIFTY_FORCE_EXIT_TIME_IST=15:00

# Enable force-exit debug payload generation.
NIFTY_FORCE_EXIT_DEBUG_ENABLED=false

# If force-exit debug is enabled, also write the payloads into the run journal.
NIFTY_FORCE_EXIT_DEBUG_TO_JOURNAL=false

# Indicator tuning used by nifty_trend_options.
NIFTY_EMA_PERIOD=20
NIFTY_SMA_PERIOD=20
NIFTY_MACD_FAST=12
NIFTY_MACD_SLOW=26
NIFTY_MACD_SIGNAL=9

# -----------------------------------------------------------------------------
# OPTIONAL GLOBAL / SELF-CONTAINED SETTINGS
# -----------------------------------------------------------------------------

# Optional in this file.
# Usually stored in config/.env instead.
# Full PostgreSQL / TimescaleDB connection URL.
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/trading_db

# Optional in this file.
# Usually stored in config/.env instead.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Astra recorder toggles.
# These are not required by strategy_runtime itself, but many operators keep them
# near runtime env files because they control whether incoming live data is persisted.
ASTRA_RECORDER_ENABLE_DB=false
ASTRA_RECORDER_ENABLE_FILE=true
