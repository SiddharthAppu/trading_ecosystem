# Copy this file to a concrete runtime env file, for example:
# config/strategy_runtime.paper_live.env
# or config/strategy_runtime.ema_cross.paper_live.env

# Live broker feed + paper execution
# Feed source options: broker | collector_sse | replay_ws
STRATEGY_RUNTIME_FEED_SOURCE=broker
STRATEGY_RUNTIME_PROVIDER=upstox
STRATEGY_RUNTIME_TRADING_PROVIDER=paper

# Collector SSE settings (used only when STRATEGY_RUNTIME_FEED_SOURCE=collector_sse)
STRATEGY_RUNTIME_COLLECTOR_BASE_URL=http://localhost:8080
STRATEGY_RUNTIME_COLLECTOR_EVENTS_PATH=/recorder/events
# Optional override (defaults to STRATEGY_RUNTIME_PROVIDER when empty)
STRATEGY_RUNTIME_COLLECTOR_PROVIDER=
STRATEGY_RUNTIME_COLLECTOR_CONNECT_TIMEOUT_SECONDS=10
STRATEGY_RUNTIME_COLLECTOR_RECONNECT_SECONDS=3
STRATEGY_RUNTIME_COLLECTOR_STALE_TIMEOUT_SECONDS=45
# collector_only | fallback_to_broker
STRATEGY_RUNTIME_COLLECTOR_FALLBACK_POLICY=collector_only

# Underlying symbol for trend detection
STRATEGY_RUNTIME_SYMBOL=NSE_INDEX|Nifty 50

# Runtime settings
STRATEGY_RUNTIME_TIMEFRAME=5m
STRATEGY_RUNTIME_POLL_SECONDS=20
STRATEGY_RUNTIME_LOOKBACK_BARS=120
STRATEGY_RUNTIME_STRATEGY=ema_cross
# Future strategy target: nifty_trend_options
STRATEGY_RUNTIME_STRATEGY_CLASS=
STRATEGY_RUNTIME_LOT_QUANTITY=1
STRATEGY_RUNTIME_LOT_SIZE=75
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000
STRATEGY_RUNTIME_MAX_POSITION_LOTS=1
STRATEGY_RUNTIME_CAPITAL_MODEL=non_compounding
STRATEGY_RUNTIME_MAX_NOTIONAL=250000
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd
STRATEGY_RUNTIME_AUTOSTART=true

# Runtime API + logging
STRATEGY_RUNTIME_LOG_LEVEL=INFO
STRATEGY_RUNTIME_LOG_FILE=logs/strategy_runtime/runtime.log

# Telegram toggle (credentials stay in config/.env)
TELEGRAM_ENABLED=false

# Replay/backtest options source alignment reference
# STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE=master_broker.v_options_ohlc_1m_fromticks

# Astra Recorder Persistence (Zero-DB mode)
ASTRA_RECORDER_ENABLE_DB=false
ASTRA_RECORDER_ENABLE_FILE=true
