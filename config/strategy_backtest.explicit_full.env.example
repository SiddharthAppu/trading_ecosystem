# strategy_backtest.explicit_full.env.example
#
# Purpose:
#   Comprehensive backtest example for scripts/strategy_backtest.py using the new
#   explicit source-table/data-kind contract and trading-day DB chunking.
#
# Usage:
#   1. Copy to a concrete file, for example:
#        config/strategy_runtime.nifty_trend_options.explicit_backtest.env
#   2. Export or load the env values.
#   3. Run scripts/strategy_backtest.py with --from and --to, or override anything
#      from the CLI as needed.
#
# Important:
#   - The backtest script now requires explicit values for:
#       STRATEGY_RUNTIME_SOURCE_TABLE
#       STRATEGY_RUNTIME_SOURCE_DATA_KIND
#       STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE
#       STRATEGY_RUNTIME_DB_CHUNKING_TRADING_DAYS
#       STRATEGY_RUNTIME_MAX_ROWS_PER_CHUNK
#   - The script validates table name format, required columns, chunk-size limits,
#     and data availability before processing begins.
#
# -----------------------------------------------------------------------------
# PRIMARY SOURCE CONTRACT
# -----------------------------------------------------------------------------

# Required.
# Exact database table containing the underlying/index source data.
# Examples:
#   master_broker.ohlcv_1m
#   broker_fyers.market_ticks
#   broker_upstox.market_ticks
#   broker_fyers.ohlcv_1m
STRATEGY_RUNTIME_SOURCE_TABLE=broker_upstox.market_ticks

# Required.
# Declares the type of rows present in STRATEGY_RUNTIME_SOURCE_TABLE.
# Allowed values:
#   ticks -> time, symbol, price, volume
#   bars  -> time, symbol, open, high, low, close, volume
STRATEGY_RUNTIME_SOURCE_DATA_KIND=ticks

# Required.
# Exact options table used for option chain discovery and historical option quotes.
STRATEGY_RUNTIME_OPTIONS_SOURCE_TABLE=master_broker.options_ohlc_1m_fromupstox

# Required.
# Number of trading days loaded into memory for each DB fetch chunk.
# Choose based on source density and machine capacity.
STRATEGY_RUNTIME_DB_CHUNKING_TRADING_DAYS=5

# Required.
# Hard fail ceiling for estimated rows in a chunk.
# If the estimate exceeds this number, the run stops before loading the chunk.
STRATEGY_RUNTIME_MAX_ROWS_PER_CHUNK=100000

# -----------------------------------------------------------------------------
# STRATEGY IDENTITY + TIMEFRAME
# -----------------------------------------------------------------------------

# Built-in strategy module name.
STRATEGY_RUNTIME_STRATEGY=nifty_trend_options

# Optional custom strategy class path.
STRATEGY_RUNTIME_STRATEGY_CLASS=

# Output timeframe for strategy evaluation.
# Allowed values currently supported by the backtest aggregation path:
#   1m
#   5m
#   10m
STRATEGY_RUNTIME_TIMEFRAME=5m

# Underlying symbol used by the backtest run unless overridden by CLI --index-symbol.
STRATEGY_RUNTIME_SYMBOL=NSE_INDEX|Nifty 50

# Indicator set computed by the backtest adapter.
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd

# -----------------------------------------------------------------------------
# POSITION SIZING + CAPITAL
# -----------------------------------------------------------------------------

# Base lots per entry.
# Special value:
#   -1 -> auto-lot sizing from available capital
STRATEGY_RUNTIME_LOT_QUANTITY=1

# Units per lot.
STRATEGY_RUNTIME_LOT_SIZE=75

# Starting capital baseline.
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000

# Capital sizing model.
# non_compounding -> fixed baseline logic
# compounding     -> size adapts to available capital
STRATEGY_RUNTIME_CAPITAL_MODEL=non_compounding

# -----------------------------------------------------------------------------
# BACKTEST-ONLY EXECUTION NOTES
# -----------------------------------------------------------------------------
# These keys exist in the wider runtime vocabulary. Some are mainly relevant to live/replay
# but are included here for completeness so operators can keep one config family.

STRATEGY_RUNTIME_MAX_POSITION_LOTS=1
STRATEGY_RUNTIME_MAX_NOTIONAL=250000
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015
STRATEGY_RUNTIME_PROVIDER=upstox
STRATEGY_RUNTIME_TRADING_PROVIDER=paper
STRATEGY_RUNTIME_FEED_SOURCE=replay_ws
STRATEGY_RUNTIME_LOG_LEVEL=INFO
STRATEGY_RUNTIME_LOG_FILE=logs/strategy_runtime/runtime.log
TELEGRAM_ENABLED=false
STRATEGY_RUNTIME_AUTOSTART=false
STRATEGY_RUNTIME_POLL_SECONDS=20
STRATEGY_RUNTIME_LOOKBACK_BARS=120
STRATEGY_RUNTIME_REPLAY_WS_URL=ws://localhost:8765
STRATEGY_RUNTIME_REPLAY_DATA_TYPE=market_ticks
STRATEGY_RUNTIME_REPLAY_SPEED=5
STRATEGY_RUNTIME_REPLAY_START_TIME=
STRATEGY_RUNTIME_REPLAY_END_TIME=
STRATEGY_RUNTIME_INDICATOR_INPUT_MODE=bars_1m

# -----------------------------------------------------------------------------
# NIFTY TREND OPTIONS STRATEGY PARAMETERS
# -----------------------------------------------------------------------------
# These are used only when STRATEGY_RUNTIME_STRATEGY=nifty_trend_options.

NIFTY_UNDERLYING_SYMBOL=NSE_INDEX|Nifty 50
NIFTY_OPTION_EXPIRY=
NIFTY_STRIKE_SCAN_COUNT=10
NIFTY_TARGET_PREMIUM=200.0
NIFTY_PREMIUM_TOLERANCE=50.0
NIFTY_STOP_LOSS_PREMIUM_PCT=0.50
NIFTY_ENTRY_START_TIME_IST=09:30
NIFTY_ENTRY_END_TIME_IST=15:00
NIFTY_FORCE_EXIT_1500_ENABLED=false
NIFTY_FORCE_EXIT_TIME_IST=15:00
NIFTY_FORCE_EXIT_DEBUG_ENABLED=false
NIFTY_FORCE_EXIT_DEBUG_TO_JOURNAL=false
NIFTY_EMA_PERIOD=20
NIFTY_SMA_PERIOD=20
NIFTY_MACD_FAST=12
NIFTY_MACD_SLOW=26
NIFTY_MACD_SIGNAL=9

# -----------------------------------------------------------------------------
# CLI-ALIGNED PARAMETERS
# -----------------------------------------------------------------------------
# The backtest script also accepts CLI arguments. These env values act as a base profile,
# while --from and --to remain mandatory command arguments in normal usage.
# Examples:
#   python scripts/strategy_backtest.py --from 2026-04-15 --to 2026-04-30
#   python scripts/strategy_backtest.py --from 2026-04-15 --to 2026-04-30 --source-table broker_fyers.market_ticks

# Optional convenience placeholders for documentation only.
# The script does not read BACKTEST_FROM_DATE or BACKTEST_TO_DATE directly.
BACKTEST_FROM_DATE=2026-04-15
BACKTEST_TO_DATE=2026-04-30

# -----------------------------------------------------------------------------
# OPTIONAL GLOBAL / SELF-CONTAINED SETTINGS
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:your_password@localhost:5432/trading_db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
