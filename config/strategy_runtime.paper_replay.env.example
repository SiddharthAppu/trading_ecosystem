# Copy this file to a strategy-specific file, for example:
# config/strategy_runtime.ema_cross.paper_replay.env
# The wrapper resolves strategy-specific files automatically.
#
# DATA AVAILABILITY (as of 2026-05-03):
#
#   broker_fyers.market_ticks        : NSE:NIFTY50-INDEX index ticks  (Apr 7 – Apr 30, ~35–41k/day)
#                                     + NIFTY options CE/PE            (~259 symbols/day)
#   broker_upstox.market_ticks       : NSE_INDEX|Nifty 50 index ticks + options (NSE_FO|... format)
#
#   broker_fyers.ohlcv_1min_from_ticks  : NSE:NIFTY50-INDEX 1m bars derived from fyers ticks
#                                          (Apr 15 – Apr 30, ~340–385 bars/day) — EOD-aggregated
#   broker_upstox.ohlcv_1min_from_ticks : NSE_INDEX|Nifty 50 1m bars (same date range)
#
#   broker_fyers.ohlcv_1m / master_broker.ohlcv_1m : NSE:NIFTY50-INDEX up to Apr 6 only
#                                                      (Upstox historical download, not live)
#
# TICK → 1m → 5m → INDICATORS:
#   Runtime TickAggregator is now enabled when:
#     STRATEGY_RUNTIME_REPLAY_DATA_TYPE=market_ticks
#     STRATEGY_RUNTIME_INDICATOR_INPUT_MODE=bars_1m
#   In this mode runtime requests market_ticks at 1m replay granularity, builds closed 1m bars,
#   then rolls those 1m bars into STRATEGY_RUNTIME_TIMEFRAME (1m/5m/10m) before indicators.

# Feed selection: broker | replay_ws
STRATEGY_RUNTIME_FEED_SOURCE=replay_ws

# Broker provider namespace for replay DB schema
STRATEGY_RUNTIME_PROVIDER=fyers
# Replay runs should always simulate execution in paper mode.
STRATEGY_RUNTIME_TRADING_PROVIDER=paper

# Symbol must exist in replay data source
STRATEGY_RUNTIME_SYMBOL=NSE:NIFTY50-INDEX

# Runtime settings
STRATEGY_RUNTIME_TIMEFRAME=5m
STRATEGY_RUNTIME_POLL_SECONDS=20
STRATEGY_RUNTIME_LOOKBACK_BARS=120
STRATEGY_RUNTIME_STRATEGY=ema_cross
# Optional plugin class, for example my_package.my_strategy.MyStrategy
STRATEGY_RUNTIME_STRATEGY_CLASS=
STRATEGY_RUNTIME_QUANTITY=1
STRATEGY_RUNTIME_INITIAL_CAPITAL=100000
STRATEGY_RUNTIME_MAX_POSITION_QTY=1
STRATEGY_RUNTIME_MAX_NOTIONAL=250000
STRATEGY_RUNTIME_STOP_LOSS_PCT=0.01
STRATEGY_RUNTIME_TRAILING_STOP_PCT=0.015
STRATEGY_RUNTIME_INDICATORS=ema_20,sma_20,rsi_14,macd
# Indicator input mode:
# - bars_1m : market_ticks are aggregated to closed 1m bars first, then to TIMEFRAME (1m/5m/10m)
# - ticks   : legacy mode, each tick is treated like a flat bar (open=high=low=close=price)
STRATEGY_RUNTIME_INDICATOR_INPUT_MODE=bars_1m
STRATEGY_RUNTIME_AUTOSTART=true

# Optional per-symbol JSON config scaffold (Phase 1 supports one symbol per process).
# If set, this overrides STRATEGY_RUNTIME_SYMBOL / PROVIDER / TIMEFRAME / REPLAY_DATA_TYPE /
# STRATEGY_RUNTIME_INDICATOR_INPUT_MODE / STRATEGY_RUNTIME_INDICATORS for the runtime process.
# indicator_input_mode is required in each symbol entry.
# Example using market_ticks with runtime tick aggregation into 1m then 5m:
# STRATEGY_RUNTIME_SYMBOL_CONFIGS_JSON={"symbols":[{"symbol":"NSE:NIFTY50-INDEX","provider":"fyers","replay_data_type":"market_ticks","timeframe":"5m","indicator_input_mode":"bars_1m","indicators":["ema_20","sma_20","rsi_14","macd"]}]}
STRATEGY_RUNTIME_SYMBOL_CONFIGS_JSON=

# Runtime API + logging
STRATEGY_RUNTIME_LOG_LEVEL=INFO
STRATEGY_RUNTIME_LOG_FILE=logs/strategy_runtime/runtime.log

# Replay source settings
STRATEGY_RUNTIME_REPLAY_WS_URL=ws://localhost:8765
# market_ticks with INDICATOR_INPUT_MODE=bars_1m:
# runtime aggregates raw ticks -> 1m bars -> TIMEFRAME (1m/5m/10m) before indicators.
STRATEGY_RUNTIME_REPLAY_DATA_TYPE=market_ticks
STRATEGY_RUNTIME_REPLAY_SPEED=5
# Use any trading day where market_ticks data exists (for fyers NSE:NIFTY50-INDEX: Apr 7 – Apr 30 2026).
STRATEGY_RUNTIME_REPLAY_START_TIME=2026-04-30T09:15:00+05:30
STRATEGY_RUNTIME_REPLAY_END_TIME=2026-04-30T15:30:00+05:30

# Telegram toggle (credentials stay in config/.env)
TELEGRAM_ENABLED=false

# Astra Recorder Persistence (Zero-DB mode)
ASTRA_RECORDER_ENABLE_DB=false
ASTRA_RECORDER_ENABLE_FILE=true
